{
  "iterate": {
    "cooldownSeconds": 30,
    "fixAttemptsPerThread": 3,
    "stallTimeoutMinutes": 30,
    "minimizeReviewSummaries": {
      "bots": true,
      "humans": true,
      "approvals": false
    }
  },
  "watch": {
    "interval": "4m",
    "readyDelayMinutes": 10,
    "expiresHours": 8,
    "maxTurns": 50
  },
  "resolve": {
    "concurrency": 4,
    "shaPoll": {
      "intervalMs": 2000,
      "maxAttempts": 10
    },
    "fetchReviewSummaries": true
  },
  "checks": {
    "ciTriggerEvents": ["pull_request", "pull_request_target"]
  },
  "mergeStatus": {
    "blockingReviewerLogins": ["copilot"]
  },
  "actions": {
    "autoResolveOutdated": true,
    "autoMarkReady": true,
    "commitSuggestions": true
  }
}
