{
  "name": "pr-shepherd",
  "version": "0.14.1",
  "description": "Autonomous PR CI monitor and review-comment resolver for agentic coding tools",
  "license": "MIT",
  "author": "Jonathan Ong",
  "type": "module",
  "bin": {
    "pr-shepherd": "bin/pr-shepherd"
  },
  "files": [
    "bin/**",
    "plugin/**",
    "plugins/**",
    "plugins/**/.codex-plugin/**",
    ".claude-plugin/**",
    ".agents/plugins/marketplace.json",
    "marketplace.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "husky": "^9.1.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "node scripts/install-husky.mjs && node scripts/install-plugin-symlink.mjs && npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ plugin/skills/ plugins/ .agents/plugins/",
    "format": "oxfmt src/ plugin/skills/ plugins/ .agents/plugins/ docs/ README.md",
    "format:check": "oxfmt --check src/ plugin/skills/ plugins/ .agents/plugins/ docs/ README.md",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "github",
    "pull-request",
    "ci",
    "code-review",
    "automation",
    "codex",
    "claude",
    "claude-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathanong/pr-shepherd.git"
  },
  "bugs": {
    "url": "https://github.com/jonathanong/pr-shepherd/issues"
  },
  "homepage": "https://github.com/jonathanong/pr-shepherd"
}
