{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./bin",
    "declaration": false,
    "sourceMap": false
  },
  "exclude": [
    "node_modules",
    "bin",
    "src/**/*.test.mts",
    "src/**/*.mock.test.mts",
    "src/**/*.test-support.mts",
    "src/**/*-test-support.mts",
    "src/**/*.fixtures.mts"
  ]
}
